@model IEnumerable<MedicalBookingSystem.Models.Appointment>

@{
    ViewData["Title"] = "Đặt Lịch Khám";
}

<div class="container mt-4">
    <h1 class="text-center mb-4">Đặt Lịch Khám</h1>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="text-end mb-3">
        <a href="/Appointments/Create" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i>Đặt Lịch Mới
        </a>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Bệnh nhân</th>
                            <th>Bác sĩ</th>
                            <th>Ngày khám</th>
                            <th>Giờ khám</th>
                            <th>Triệu chứng</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var appointment in Model)
                        {
                            <tr>
                                <td>@appointment.PatientName</td>
                                <td>@appointment.Doctor?.Name</td>
                                <td>@appointment.AppointmentDate.ToString("dd/MM/yyyy")</td>
                                <td>@appointment.AppointmentTime</td>
                                <td>@(appointment.Symptoms ?? "Không có")</td>
                                <td>
                                    <span class="badge bg-warning">@appointment.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="fas fa-calendar-times fa-3x text-muted mb-3"></i>
                <h4 class="text-muted">Chưa có lịch hẹn nào</h4>
                <a href="/Appointments/Create" class="btn btn-primary mt-3">
                    <i class="fas fa-calendar-plus me-2"></i>Đặt Lịch Ngay
                </a>
            </div>
        }
    </div>
</div>