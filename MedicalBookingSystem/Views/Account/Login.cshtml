@model MedicalBookingSystem.Controllers.LoginViewModel
@{
    ViewData["Title"] = "Đăng Nhập";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white text-center py-4">
                    <h2 class="mb-0"><i class="fas fa-sign-in-alt me-2"></i>ĐĂNG NHẬP</h2>
                    <p class="mb-0 mt-2">Đăng nhập để tiếp tục sử dụng dịch vụ</p>
                </div>
                <div class="card-body p-5">
                    <form method="post">
                        @Html.AntiForgeryToken()

                        <div class="form-group mb-4">
                            <label asp-for="Email" class="form-label fw-bold">
                                <i class="fas fa-envelope me-2"></i>Email
                            </label>
                            <input asp-for="Email" class="form-control form-control-lg"
                                   placeholder="Nhập email của bạn" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Password" class="form-label fw-bold">
                                <i class="fas fa-lock me-2"></i>Mật khẩu
                            </label>
                            <input asp-for="Password" type="password" class="form-control form-control-lg"
                                   placeholder="Nhập mật khẩu" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <div class="form-check">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label asp-for="RememberMe" class="form-check-label">
                                    Ghi nhớ đăng nhập
                                </label>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mb-4">
                            <button type="submit" class="btn btn-success btn-lg py-3 fw-bold">
                                <i class="fas fa-sign-in-alt me-2"></i>ĐĂNG NHẬP
                            </button>
                        </div>

                        <div class="text-center">
                            <p class="mb-2">
                                <a href="#" class="text-primary">Quên mật khẩu?</a>
                            </p>
                            <p class="mb-0">
                                Chưa có tài khoản?
                                <a href="/Account/Register" class="text-primary fw-bold">Đăng ký ngay</a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}